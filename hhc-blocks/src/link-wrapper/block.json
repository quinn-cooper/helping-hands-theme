{
  "apiVersion": 3,
  "name": "hhc-blocks/link-wrapper",
  "title": "Link Wrapper",
  "category": "design",
  "icon": "admin-links",
  "description": "Makes an entire block group clickable.",
  "attributes": {
    "url": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "anchor": false,
    "reusable": false,
    "multiple": true
  },

  "allowedBlocks": [
	"core/group",
    "core/heading",
    "core/paragraph"
  ],

  "templateLock": "all",

  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css"
}

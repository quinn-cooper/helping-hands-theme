{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#f2e9dd",
					"name": "Main background",
					"slug": "custom-main-background"
				},
				{
					"color": "#14243e",
					"name": "Main text",
					"slug": "custom-main-text"
				},
				{
					"color": "#2c4a7a",
					"name": "Icons & CTAs",
					"slug": "custom-icons-ct-as"
				},
				{
					"color": "#7bbdbb",
					"name": "Secondary background",
					"slug": "custom-secondary-background"
				},
				{
					"color": "#664024",
					"name": "Links, secondary background",
					"slug": "custom-links-secondary-background"
				},
				{
					"color": "#eab394",
					"name": "Secondary background",
					"slug": "custom-secondary-background-1"
				}
			]
		},
		"layout": {
			"contentSize": "55rem",
			"wideSize": "62.5px"
		},
		"shadow": {
			"presets": []
		},
		"spacing": {
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "100",
							"src": [
								"file:./assets/fonts/lato/lato-100-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/lato/lato-300-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/lato/lato-700-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "100",
							"src": [
								"file:./assets/fonts/lato/lato-100-italic.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/lato/lato-300-italic.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-400-italic.woff2"
							]
						}
					],
					"fontFamily": "Lato, sans-serif",
					"name": "Lato",
					"slug": "lato"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Cormorant Infant\"",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/cormorant-infant/cormorant-infant-300-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Cormorant Infant\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/cormorant-infant/cormorant-infant-400-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Cormorant Infant\"",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/cormorant-infant/cormorant-infant-500-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Cormorant Infant\"",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/cormorant-infant/cormorant-infant-600-normal.woff2"
							]
						},
						{
							"fontFamily": "\"Cormorant Infant\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/cormorant-infant/cormorant-infant-700-normal.woff2"
							]
						}
					],
					"fontFamily": "\"Cormorant Infant\", serif",
					"name": "Cormorant Infant",
					"slug": "cormorant-infant"
				}
			],
			"fontSizes": []
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/accordion-heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)"
				}
			},
			"core/button": {
				"border": {
					"radius": {
						"bottomLeft": "5px",
						"bottomRight": "5px",
						"topLeft": "5px",
						"topRight": "5px"
					}
				},
				"color": {
					"background": "var(--wp--preset--color--custom-icons-ct-as)",
					"text": "var(--wp--preset--color--custom-main-background)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--custom-main-background)"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)",
					"fontSize": "1.1rem",
					"fontStyle": "normal",
					"fontWeight": "400"
				},
				"variations": {
					"outline": {
						"border": {
							"bottom": {
								"color": "currentColor",
								"style": "solid",
								"width": "2px"
							},
							"left": {
								"color": "currentColor",
								"style": "solid",
								"width": "2px"
							},
							"radius": {
								"bottomLeft": "5px",
								"bottomRight": "5px",
								"topLeft": "5px",
								"topRight": "5px"
							},
							"right": {
								"color": "currentColor",
								"style": "solid",
								"width": "2px"
							},
							"top": {
								"color": "currentColor",
								"style": "solid",
								"width": "2px"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--custom-main-text)"
						},
						"typography": {
							"fontFamily": "var(--wp--preset--font-family--lato)",
							"fontSize": "1.1rem",
							"fontStyle": "normal",
							"fontWeight": "400"
						}
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--custom-main-background)",
			"text": "var(--wp--preset--color--custom-main-text)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--custom-icons-ct-as)",
					"text": "var(--wp--preset--color--custom-main-background)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "400",
					"textTransform": "uppercase"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--custom-icons-ct-as)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "italic",
					"fontWeight": "300",
					"textTransform": "none"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "2.9rem",
					"fontStyle": "normal",
					"fontWeight": "700",
					"lineHeight": "1.5"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "2.4rem",
					"fontStyle": "normal",
					"fontWeight": "500"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "1.9rem",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "1.4rem",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "1.1rem",
					"fontStyle": "normal",
					"fontWeight": "700",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)",
					"fontSize": "1.1rem",
					"fontStyle": "normal",
					"fontWeight": "400",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--custom-main-text)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-infant)"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--custom-icons-ct-as)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--custom-links-secondary-background)"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--20)",
			"padding": {
				"bottom": "0",
				"left": "0px",
				"right": "0px",
				"top": "0"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--lato)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontStyle": "normal",
			"fontWeight": "300",
			"lineHeight": "1.5"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	]
}